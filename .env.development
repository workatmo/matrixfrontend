# Loaded only for `npm run dev`. Overrides LARAVEL_PROXY_TARGET from `.env` so `/api-backend`
# hits your local Laravel (`php artisan serve`), i.e. the same database you see in phpMyAdmin.
# Remove or comment this file if you intentionally want localhost:3000 to use the live API.
LARAVEL_PROXY_TARGET=https://api.matrixmobiletyresandautos.com
