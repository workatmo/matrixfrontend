DirectoryIndex index.html
Options -MultiViews

RewriteEngine On
RewriteBase /

# Serve existing files directly.
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Avoid directory-listing 403 on exported routes like /admin/login/
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Map extensionless routes to .html files generated by static export.
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Root route.
RewriteRule ^$ index.html [L]

# Custom 404 page from static export.
ErrorDocument 404 /404.html

