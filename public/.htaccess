DirectoryIndex index.html
Options -MultiViews
DirectorySlash Off

RewriteEngine On
RewriteBase /

# HSTS — only when the request is HTTPS (direct TLS or behind a proxy that sets X-Forwarded-Proto).
<IfModule mod_headers.c>
  <IfModule mod_setenvif.c>
    SetEnvIf HTTPS "on" MATRIX_HSTS=1
    SetEnvIf X-Forwarded-Proto "^https$" MATRIX_HSTS=1
  </IfModule>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=MATRIX_HSTS
</IfModule>

# Serve existing files directly.
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If a directory exists but its sibling .html exists (e.g. /search/ -> /search.html),
# serve the .html file. This avoids Apache's automatic slash redirects causing loops.
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Map extensionless routes to .html files generated by static export.
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Root route.
RewriteRule ^$ index.html [L]

# Custom 404 page from static export.
ErrorDocument 404 /404.html

