# Browser → same-origin `/api-backend/*` → Next rewrites to Laravel `/api/*` (no CORS in browser).
# Production API host (omit trailing slash; `/api` is added by next.config.mjs).
NEXT_PUBLIC_API_URL=/api-backend
LARAVEL_PROXY_TARGET=https://api.matrixmobiletyresandautos.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
