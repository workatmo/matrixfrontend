# Copy to `.env` and adjust for your machine.
# Restart `next dev` after changing env vars.

# API base path/URL:
# - Local (recommended): `/api-backend` — proxied by Next to Laravel (see next.config.mjs), no CORS issues.
# - Or direct: `http://127.0.0.1:8000/api` if you prefer cross-origin calls (configure Laravel CORS).
NEXT_PUBLIC_API_URL=/api-backend

# Where Next should proxy `/api-backend/*` (server-side only, not exposed to the browser)
LARAVEL_PROXY_TARGET=http://127.0.0.1:8000

# This app’s public URL (used for links / future OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
