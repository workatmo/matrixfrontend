# Browser calls same-origin /api-backend/* → Next.js proxies to Laravel (no CORS for public tyre APIs).
# On Vercel/Node: set LARAVEL_PROXY_TARGET to your API origin (no /api suffix).
NEXT_PUBLIC_API_URL=/api-backend
LARAVEL_PROXY_TARGET=https://api.matrixmobiletyresandautos.com
NEXT_PUBLIC_APP_URL=https://matrixmobiletyresandautos.com

# Used at build time for generateStaticParams (server fetch; must be absolute URL).
NEXT_PUBLIC_STATIC_API_URL=https://api.matrixmobiletyresandautos.com/api
