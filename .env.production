# Loaded when NODE_ENV=production (`next build` / `next start`).
# Browser → same-origin `NEXT_PUBLIC_API_URL/*` → Next rewrites to Laravel `/api/*` when URL is relative.
NEXT_PUBLIC_API_URL=/api-backend
LARAVEL_PROXY_TARGET=https://api.matrixmobiletyresandautos.com
# Deployed site origin (metadata, absolute URLs). Example: https://admin.yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
